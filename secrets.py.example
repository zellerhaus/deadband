# Wi-Fi credentials and any other secrets used by community firmware.
#
# 1. Copy this file to `secrets.py` (drop the .example suffix).
# 2. Fill in your real values.
# 3. Never commit `secrets.py` — it is gitignored by default.
#
# Share `secrets.py.example` with collaborators, never `secrets.py`.

secrets = {
    # Required for any firmware that uses Wi-Fi.
    "ssid": "your-wifi-network",
    "password": "your-wifi-password",

    # Optional — used by webhook examples.
    # "webhook_url": "https://hooks.example.com/your-endpoint",

    # Optional — used by MQTT examples.
    # "mqtt_broker": "homeassistant.local",
    # "mqtt_port": 1883,
    # "mqtt_username": "user",
    # "mqtt_password": "password",

    # Optional — used by API-key examples.
    # "api_key": "...",
}
